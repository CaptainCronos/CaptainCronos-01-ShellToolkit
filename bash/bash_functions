_ts_files() {
    ls -1t /var/log/timeshift/*log* 2>/dev/null | head -n 12
}

# @name tslast
# @group Timeshift
# @desc Show the newest Timeshift log file.
# @usage tslast
# @example tslast
tslast() {
    _ts_files | head -n 1
}

# @name tslog
# @group Timeshift
# @desc Search recent Timeshift logs; optional first number controls output line count.
# @usage tslog [lines] <pattern>
# @example tslog error
# @example tslog 300 rsync
tslog() {
    local n=200 pattern file

    if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        n="$1"
        shift
    fi

    pattern="$*"
    if [ -z "$pattern" ]; then
        echo "Usage: tslog [lines] <pattern>"
        return 1
    fi

    for file in $(_ts_files); do
        if [[ "$file" == *.gz ]]; then
            gzip -cd -- "$file" | grep -i -- "$pattern" || true
        else
            grep -i -- "$pattern" -- "$file" || true
        fi
    done | tail -n "$n"
}

# @name tsfollow
# @group Timeshift
# @desc Follow the current Timeshift log file.
# @usage tsfollow
# @example tsfollow
tsfollow() {
    local current next
    current="$(tslast)"
    [ -n "$current" ] || { echo "No Timeshift logs found."; return 1; }

    echo "Following: $current"

    while :; do
        next="$(tslast)"
        if [ "$next" != "$current" ] && [ -n "$next" ]; then
            echo "Switching to: $next"
            exec tail -F "$next"
        fi
        sleep 10
    done &

    tail -F "$current"
}

# @name tsdf
# @group Timeshift
# @desc Watch Timeshift filesystem usage.
# @usage tsdf
# @example tsdf
tsdf() {
    watch -n 15 'df -h /timeshift'
}

