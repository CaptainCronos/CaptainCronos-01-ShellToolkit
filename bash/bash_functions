# @name loadavg
# @group System
# @desc Show system load averages for 1, 5, and 15 minutes.
# @usage loadavg
# @example loadavg
loadavg() {
    awk '{print "Load Averages: "$1" "$2" "$3" (1m:5m:15m)"}' /proc/loadavg
}

# @name space
# @group Filesystem
# @desc Show total disk usage for a directory.
# @usage space <directory>
# @example space /timeshift-usb
# @example space ~/Downloads
space() {
    if [ "$#" -lt 1 ] || [ ! -d "$1" ]; then
        echo "Usage: space <directory>"
        return 1
    fi
    sudo du -sh -- "$1" | awk '{print $1}'
}

# @name findharddrives
# @group Filesystem
# @desc Show physical drives, filesystems, labels, UUIDs, usage, and mount points.
# @usage findharddrives
# @example findharddrives
findharddrives() {
    lsblk -e 7 -o NAME,FSTYPE,LABEL,UUID,SIZE,FSAVAIL,FSUSE%,MOUNTPOINTS
}

