# @name bf
# @group Editors
# @desc Edit files with Bluefish when available, otherwise nano; request root when needed.
# @usage bf <file> [file...]
# @example bf ~/.bashrc
# @example bf /etc/fstab
bf() {
    local editor file
    editor="$(command -v bluefish || printf '%s' "${EDITOR:-/bin/nano}")"

    if [ "$#" -eq 0 ]; then
        echo "Usage: bf <file> [file...]"
        return 1
    fi

    for file in "$@"; do
        if [ -w "$file" ] || [ ! -e "$file" ]; then
            "$editor" "$file" &
        else
            echo "Requesting root access for: $file"
            pkexec env DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" "$editor" "$file" &
        fi
    done
}

