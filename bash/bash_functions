# @name extract
# @group Archives
# @desc Extract common tar archive formats.
# @usage extract <archive>
# @example extract backup.tar.gz
# @example extract source.tar.xz
extract() {
    if [ "$#" -ne 1 ]; then
        echo "Usage: extract <archive>"
        return 1
    fi

    case "$1" in
        *.tar.xz|*.txz) tar -xJf "$1" ;;
        *.tar.gz|*.tgz) tar -xzf "$1" ;;
        *.tar.bz2)      tar -xjf "$1" ;;
        *.tar)          tar -xf "$1" ;;
        *) echo "Unknown archive format: $1"; return 1 ;;
    esac
}

# @name maketar
# @group Archives
# @desc Create a gzip-compressed tar archive.
# @usage maketar <archive.tar.gz> <file-or-directory> [more...]
# @example maketar backup.tar.gz ~/Documents
maketar() {
    if [ "$#" -lt 2 ]; then
        echo "Usage: maketar <archive.tar.gz> <file-or-directory> [more...]"
        return 1
    fi
    tar -zcpf "$@"
}

# =============================
# TIMESHIFT HELPERS
