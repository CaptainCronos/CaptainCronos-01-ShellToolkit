# @name findopenports
# @group Network
# @desc Run a full TCP SYN port scan against a target using nmap.
# @usage findopenports [target]
# @example findopenports
# @example findopenports 192.168.1.10
findopenports() {
    local target="${1:-localhost}"
    sudo nmap -sS -p- "$target"
}

