#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : cc
# Version     : reads VERSION
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Unified command front-end for Captain Cronos Shell Toolkit.
# ==============================================================================

set -euo pipefail

DEFAULT_REPO="$HOME/GitHub/CaptainCronos-01-ShellToolkit"
PROJECT_ROOT="${CAPTAIN_CRONOS_REPO:-}"

if [ -z "$PROJECT_ROOT" ]; then
    PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi

if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT" ]; then
    PROJECT_ROOT="$DEFAULT_REPO"
fi

if [ ! -d "$PROJECT_ROOT" ]; then
    echo "[CC ERROR] Repository not found: $PROJECT_ROOT" >&2
    echo "Set CAPTAIN_CRONOS_REPO or clone to: $DEFAULT_REPO" >&2
    exit 1
fi

cd "$PROJECT_ROOT"

source "$PROJECT_ROOT/lib/cc-common.sh"

show_help() {
    cat <<'EOF_HELP'
Captain Cronos Shell Toolkit Command Front-End
==============================================

Usage:
  cc <command> [options]

Commands:
  install      Install the Shell Toolkit locally.
  update       Pull latest changes and reinstall the Shell Toolkit.
  verify       Verify repository structure and Bash syntax.
  doctor       Run repository and installation health checks.
  version      Show toolkit version information.
  baseline     Capture operating-system baseline shell files.
  defaults     Promote active shell files into defaults/v1.
  repo         Show repository path used by cc.
  help         Show this help.

Examples:
  cc version
  cc repo
  cc verify
  cc doctor
  cc install --dry-run
  cc update
  cc baseline
  cc defaults

Notes:
  This command can be run from anywhere after install/install.sh places it in ~/bin.
EOF_HELP
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    help|--help|-h)
        show_help
        ;;
    repo)
        echo "$PROJECT_ROOT"
        ;;
    version|--version)
        cc_version
        ;;
    install)
        exec install/install.sh "$@"
        ;;
    update|upgrade)
        exec install/update.sh "$@"
        ;;
    verify)
        exec install/verify.sh "$@"
        ;;
    doctor)
        exec tools/cc-doctor "$@"
        ;;
    baseline)
        exec install/create-baseline.sh "$@"
        ;;
    defaults|promote-defaults)
        exec install/promote-defaults.sh "$@"
        ;;
    *)
        cc_error "Unknown command: $cmd"
        echo
        show_help
        exit 1
        ;;
esac
