#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : cc
# Version     : reads VERSION
# Category    : Core
# Requires    : bash git grep sed awk
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Unified command dispatcher for Captain Cronos Shell Toolkit.
# ==============================================================================

set -euo pipefail

DEFAULT_REPO="$HOME/GitHub/CaptainCronos-01-ShellToolkit"
PROJECT_ROOT="${CAPTAIN_CRONOS_REPO:-}"

if [ -z "$PROJECT_ROOT" ]; then
    PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi

if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT" ]; then
    PROJECT_ROOT="$DEFAULT_REPO"
fi

if [ ! -d "$PROJECT_ROOT" ]; then
    echo "[CC ERROR] Repository not found: $PROJECT_ROOT" >&2
    echo "Set CAPTAIN_CRONOS_REPO or clone to: $DEFAULT_REPO" >&2
    exit 1
fi

cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-deps.sh"

COMMAND_DIR="$PROJECT_ROOT/tools/commands"

show_help() {
    echo "Captain Cronos Shell Toolkit"
    echo "============================"
    echo
    echo "Usage:"
    echo "  cc <command> [options]"
    echo
    echo "Commands:"
    if [ -d "$COMMAND_DIR" ]; then
        for command_file in "$COMMAND_DIR"/*; do
            [ -f "$command_file" ] || continue
            command_name="$(basename "$command_file")"
            command_desc="$(grep -m 1 '^# Purpose     :' "$command_file" | sed 's/^# Purpose     : //')"
            printf "  %-12s %s\n" "$command_name" "${command_desc:-No description.}"
        done | sort
    fi
    echo
    echo "Examples:"
    echo "  cc version"
    echo "  cc repo"
    echo "  cc doctor"
    echo "  cc install --dry-run"
    echo "  cc update"
    echo
    echo "Repository: $PROJECT_ROOT"
}

script_field() {
    local file="$1" field="$2"
    awk -v field="$field" '
        $0 ~ "^# " field "[[:space:]]*:" {
            sub("^# " field "[[:space:]]*:[[:space:]]*", "")
            print
            exit
        }
    ' "$file"
}

check_command_deps() {
    local file="$1" command_name="$2" deps dep missing=0 package
    deps="$(script_field "$file" "Requires")"
    [ -n "$deps" ] || return 0

    for dep in $deps; do
        case "$dep" in
            bash|sh)
                continue
                ;;
        esac
        if ! cc_dep_exists "$dep"; then
            if [ "$missing" -eq 0 ]; then
                cc_error "Missing required dependency for cc $command_name"
                echo
                echo "Dependency Check"
                echo "----------------"
            fi
            package="$(cc_dep_package_hint "$dep")"
            printf '%-18s %s' "$dep" "MISSING"
            if [ -n "$package" ] && [ "$package" != "$dep" ]; then
                printf '  install package: %s' "$package"
            fi
            printf '\n'
            missing=$((missing + 1))
        fi
    done

    if [ "$missing" -gt 0 ]; then
        echo
        echo "Resolve missing dependencies and retry."
        if command -v apt >/dev/null 2>&1; then
            echo
            echo "Ubuntu/Debian hint:"
            printf '  sudo apt install'
            for dep in $deps; do
                cc_dep_exists "$dep" || printf ' %s' "$(cc_dep_package_hint "$dep")"
            done
            printf '\n'
        fi
        exit 127
    fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    help|--help|-h)
        show_help
        exit 0
        ;;
    --version)
        cmd="version"
        ;;
esac

command_path="$COMMAND_DIR/$cmd"

if [ ! -f "$command_path" ]; then
    cc_error "Unknown command: $cmd"
    echo
    show_help
    exit 1
fi

check_command_deps "$command_path" "$cmd"

bash "$command_path" "$@"
