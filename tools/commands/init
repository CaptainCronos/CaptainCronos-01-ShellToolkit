#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : init
# Version     : 1.0.0-alpha1
# Category    : Core
# Requires    : bash hostname mkdir install grep
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Initialize a Captain Cronos host identity and local environment.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-environment.sh"

APPLY=0
HOST_ID_INPUT=""
ROLE="workstation"
PROFILE="default"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc init [--apply] [--host-id ID] [--role ROLE] [--profile PROFILE]

Initializes a portable Captain Cronos host identity.

Creates:
  ~/.captaincronos/hosts/<host-id>/config
  ~/.captaincronos/hosts/<host-id>/reports
  ~/.captaincronos/hosts/<host-id>/assets
  ~/.captaincronos/hosts/<host-id>/cache
  ~/.captaincronos/hosts/<host-id>/logs
  ~/.captaincronos/hosts/<host-id>/plugins

Also verifies ~/bin and installs the cc launcher when --apply is used.

Default is dry-run.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.0.0-alpha1"
            exit 0
            ;;
        --apply)
            APPLY=1
            shift
            ;;
        --host-id)
            shift
            HOST_ID_INPUT="${1:-}"
            [ -n "$HOST_ID_INPUT" ] || { usage; exit 1; }
            shift
            ;;
        --role)
            shift
            ROLE="${1:-}"
            [ -n "$ROLE" ] || { usage; exit 1; }
            shift
            ;;
        --profile)
            shift
            PROFILE="${1:-}"
            [ -n "$PROFILE" ] || { usage; exit 1; }
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

if [ -n "$HOST_ID_INPUT" ]; then
    export CC_HOST_ID
    CC_HOST_ID="$(cc_env_safe_id "$HOST_ID_INPUT")"
fi

HOST_ID="$(cc_env_host_id)"
HOST_HOME="$(cc_env_host_home)"
CONFIG_FILE="$(cc_env_config)"

path_has_home_bin() {
    case ":$PATH:" in
        *":$HOME/bin:"*) return 0 ;;
        *) return 1 ;;
    esac
}

write_config() {
    cat > "$CONFIG_FILE" <<EOF_CONFIG
# Captain Cronos host configuration
HOST_ID="$HOST_ID"
HOST_ROLE="$ROLE"
HOST_PROFILE="$PROFILE"
REPO_ROOT="$HOME/GitHub"
REPORT_DIR="$(cc_env_report_dir)"
ASSET_DIR="$(cc_env_asset_dir)"
PLUGIN_DIR="$(cc_env_plugin_dir)"
CACHE_DIR="$(cc_env_cache_dir)"
LOG_DIR="$(cc_env_log_dir)"
EDITOR="nano"
AUTO_DOCS="no"
AUTO_PUSH="no"
EOF_CONFIG
}

cc_banner
printf '%-16s %s\n' "Apply:" "$APPLY"
printf '%-16s %s\n' "Linux host:" "$(hostname 2>/dev/null || echo unknown)"
printf '%-16s %s\n' "Host ID:" "$HOST_ID"
printf '%-16s %s\n' "Role:" "$ROLE"
printf '%-16s %s\n' "Profile:" "$PROFILE"
printf '%-16s %s\n' "Host Home:" "$HOST_HOME"
echo

if [ "$APPLY" -eq 0 ]; then
    cc_log "DRY RUN: would initialize Captain Cronos host environment."
    [ -d "$HOME/bin" ] && cc_log "~/bin exists." || cc_warn "~/bin missing; would create."
    path_has_home_bin && cc_log "~/bin is in PATH." || cc_warn "~/bin not found in PATH."
    [ -f "$HOME/bin/cc" ] && cc_log "~/bin/cc exists." || cc_warn "~/bin/cc missing; would install launcher."
    [ -f "$CONFIG_FILE" ] && cc_log "Host config exists: $CONFIG_FILE" || cc_warn "Host config missing; would create."
    echo
    cc_log "Re-run with: cc init --apply"
    exit 0
fi

mkdir -p "$HOME/bin"
cc_env_init_dirs
write_config
chmod 700 "$(cc_env_home)" "$(cc_env_home)/hosts" "$HOST_HOME" 2>/dev/null || true
chmod 755 "$HOME/bin"

if [ -f "$PROJECT_ROOT/tools/cc" ]; then
    install -m 755 "$PROJECT_ROOT/tools/cc" "$HOME/bin/cc"
    cc_log "Installed cc launcher: $HOME/bin/cc"
else
    cc_warn "Missing tools/cc; launcher not installed."
fi

if path_has_home_bin; then
    cc_log "~/bin is already in PATH."
else
    cc_warn "~/bin is not currently in PATH."
    cc_warn "Add this to your shell profile if needed: export PATH=\"$HOME/bin:\$PATH\""
fi

echo
cc_log "Captain Cronos host identity initialized."
echo
cc_env_summary
