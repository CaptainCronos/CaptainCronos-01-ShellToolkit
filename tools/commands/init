#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : init
# Version     : 1.1.0-alpha1
# Category    : Core
# Requires    : bash hostname mkdir install grep awk uname command
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Initialize a Captain Cronos host identity and local environment.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-environment.sh"
source "$PROJECT_ROOT/lib/cc-platform.sh"

APPLY=0
HOST_ID_INPUT=""
ROLE=""
PROFILE=""
INTERACTIVE=0
RUN_SELFTEST=0

usage() {
    cat <<'EOF_HELP'
Usage:
  cc init [--apply] [--host-id ID] [--role ROLE] [--profile PROFILE]
  cc init --interactive [--apply]

Initializes a portable Captain Cronos host identity.

Roles:
  developer   Development workstation
  workbench   Live USB / drive qualification bench
  server      General Linux server
  nas         NAS appliance or NAS-adjacent host
  laptop      Mobile workstation

Profiles:
  developer
  workbench
  server
  truenas-scale
  laptop
  default

Default is dry-run.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.1.0-alpha1"
            exit 0
            ;;
        --apply)
            APPLY=1
            shift
            ;;
        --interactive)
            INTERACTIVE=1
            shift
            ;;
        --selftest)
            RUN_SELFTEST=1
            shift
            ;;
        --host-id)
            shift
            HOST_ID_INPUT="${1:-}"
            [ -n "$HOST_ID_INPUT" ] || { usage; exit 1; }
            shift
            ;;
        --role)
            shift
            ROLE="${1:-}"
            [ -n "$ROLE" ] || { usage; exit 1; }
            shift
            ;;
        --profile)
            shift
            PROFILE="${1:-}"
            [ -n "$PROFILE" ] || { usage; exit 1; }
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

if [ -n "$HOST_ID_INPUT" ]; then
    export CC_HOST_ID
    CC_HOST_ID="$(cc_env_safe_id "$HOST_ID_INPUT")"
fi

infer_role() {
    case "$(cc_platform_type)" in
        truenas-scale) echo nas ;;
        *) echo developer ;;
    esac
}

suggest_profile() {
    if [ -n "$PROFILE" ]; then
        echo "$PROFILE"
    else
        cc_platform_infer_profile
    fi
}

interactive_select() {
    local selection
    echo
    echo "Select Role"
    echo "-----------"
    echo "1) developer"
    echo "2) workbench"
    echo "3) server"
    echo "4) nas"
    echo "5) laptop"
    echo "6) custom/default"
    printf 'Selection [%s]: ' "${ROLE:-$(infer_role)}"
    read -r selection || true
    case "$selection" in
        1) ROLE="developer"; PROFILE="developer" ;;
        2) ROLE="workbench"; PROFILE="workbench" ;;
        3) ROLE="server"; PROFILE="server" ;;
        4) ROLE="nas"; PROFILE="truenas-scale" ;;
        5) ROLE="laptop"; PROFILE="laptop" ;;
        6) ROLE="${ROLE:-custom}"; PROFILE="${PROFILE:-default}" ;;
        "") ROLE="${ROLE:-$(infer_role)}"; PROFILE="${PROFILE:-$(suggest_profile)}" ;;
        *) ROLE="$selection"; PROFILE="${PROFILE:-default}" ;;
    esac
}

ROLE="${ROLE:-$(infer_role)}"
PROFILE="${PROFILE:-$(suggest_profile)}"

if [ "$INTERACTIVE" -eq 1 ]; then
    cc_banner
    echo
    echo "Host Initialization"
    echo "-------------------"
    printf '%-16s %s\n' "Hostname:" "$(hostname 2>/dev/null || echo unknown)"
    printf '%-16s %s\n' "Platform:" "$(cc_platform_name)"
    printf '%-16s %s\n' "Detected type:" "$(cc_platform_type)"
    interactive_select
fi

HOST_ID="$(cc_env_host_id)"
HOST_HOME="$(cc_env_host_home)"
CONFIG_FILE="$(cc_env_config)"

path_has_home_bin() {
    case ":$PATH:" in
        *":$HOME/bin:"*) return 0 ;;
        *) return 1 ;;
    esac
}

profile_defaults() {
    case "$PROFILE" in
        developer)
            echo 'AUTO_DOCS="yes"'
            echo 'AUTO_PUSH="no"'
            echo 'READ_ONLY="no"'
            ;;
        workbench)
            echo 'AUTO_DOCS="no"'
            echo 'AUTO_PUSH="no"'
            echo 'READ_ONLY="no"'
            echo 'DRIVE_QUALIFICATION="yes"'
            ;;
        truenas-scale)
            echo 'AUTO_DOCS="no"'
            echo 'AUTO_PUSH="no"'
            echo 'READ_ONLY="yes"'
            echo 'NO_SYSTEM_UPDATE="yes"'
            ;;
        laptop)
            echo 'AUTO_DOCS="no"'
            echo 'AUTO_PUSH="no"'
            echo 'READ_ONLY="no"'
            ;;
        *)
            echo 'AUTO_DOCS="no"'
            echo 'AUTO_PUSH="no"'
            echo 'READ_ONLY="no"'
            ;;
    esac
}

write_config() {
    cat > "$CONFIG_FILE" <<EOF_CONFIG
# Captain Cronos host configuration
HOST_ID="$HOST_ID"
HOST_ROLE="$ROLE"
HOST_PROFILE="$PROFILE"
HOST_PLATFORM="$(cc_platform_type)"
HOST_OS="$(cc_platform_os_id)"
HOST_OS_VERSION="$(cc_platform_os_version)"
HOST_ARCH="$(cc_platform_arch)"
PACKAGE_MANAGER="$(cc_platform_package_manager)"
INIT_SYSTEM="$(cc_platform_init_system)"
REPO_ROOT="$HOME/GitHub"
REPORT_DIR="$(cc_env_report_dir)"
ASSET_DIR="$(cc_env_asset_dir)"
PLUGIN_DIR="$(cc_env_plugin_dir)"
CACHE_DIR="$(cc_env_cache_dir)"
LOG_DIR="$(cc_env_log_dir)"
EDITOR="nano"
$(profile_defaults)
EOF_CONFIG
}

cc_banner
printf '%-18s %s\n' "Apply:" "$APPLY"
printf '%-18s %s\n' "Linux host:" "$(hostname 2>/dev/null || echo unknown)"
printf '%-18s %s\n' "Platform:" "$(cc_platform_type)"
printf '%-18s %s\n' "Package mgr:" "$(cc_platform_package_manager)"
printf '%-18s %s\n' "Host ID:" "$HOST_ID"
printf '%-18s %s\n' "Role:" "$ROLE"
printf '%-18s %s\n' "Profile:" "$PROFILE"
printf '%-18s %s\n' "Host Home:" "$HOST_HOME"
echo

if [ "$APPLY" -eq 0 ]; then
    cc_log "DRY RUN: would initialize Captain Cronos host environment."
    [ -d "$HOME/bin" ] && cc_log "~/bin exists." || cc_warn "~/bin missing; would create."
    path_has_home_bin && cc_log "~/bin is in PATH." || cc_warn "~/bin not found in PATH."
    [ -f "$HOME/bin/cc" ] && cc_log "~/bin/cc exists." || cc_warn "~/bin/cc missing; would install launcher."
    [ -f "$CONFIG_FILE" ] && cc_log "Host config exists: $CONFIG_FILE" || cc_warn "Host config missing; would create."
    echo
    cc_log "Re-run with: cc init --apply"
    exit 0
fi

mkdir -p "$HOME/bin"
cc_env_init_dirs
write_config
chmod 700 "$(cc_env_home)" "$(cc_env_home)/hosts" "$HOST_HOME" 2>/dev/null || true
chmod 755 "$HOME/bin"

if [ -f "$PROJECT_ROOT/tools/cc" ]; then
    install -m 755 "$PROJECT_ROOT/tools/cc" "$HOME/bin/cc"
    cc_log "Installed cc launcher: $HOME/bin/cc"
else
    cc_warn "Missing tools/cc; launcher not installed."
fi

if path_has_home_bin; then
    cc_log "~/bin is already in PATH."
else
    cc_warn "~/bin is not currently in PATH."
    cc_warn "Add this to your shell profile if needed: export PATH=\"$HOME/bin:\$PATH\""
fi

echo
cc_log "Captain Cronos host identity initialized."
echo
cc_env_summary

echo
cc_log "Capability summary:"
while read -r cap; do
    [ -n "$cap" ] || continue
    printf '%-18s %s\n' "$cap" "$(cc_capability_status "$cap")"
done < <(cc_capability_list)

if [ "$RUN_SELFTEST" -eq 1 ]; then
    echo
    bash "$PROJECT_ROOT/tools/cc" selftest
fi
