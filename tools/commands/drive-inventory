#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-inventory
# Version     : 1.1.0-alpha1
# Category    : Storage
# Requires    : bash lsblk smartctl awk grep paste
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Show physical drive inventory with identity and SMART basics.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-smart.sh"
source "$PROJECT_ROOT/lib/cc-storage.sh"

FORMAT="table"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-inventory [table|csv|markdown]

Shows attached block devices with model, serial, size, transport, mountpoints, and SMART basics.

This is read-only inventory output. It does not start SMART tests or modify disks.
EOF_HELP
}

if [ "$#" -gt 0 ]; then
    case "$1" in
        --help|-h) usage; exit 0 ;;
        --version) echo "1.1.0-alpha1"; exit 0 ;;
        table|csv|markdown) FORMAT="$1" ;;
        *) usage; exit 1 ;;
    esac
fi

if ! command -v lsblk >/dev/null 2>&1; then
    cc_error "lsblk not found."
    exit 127
fi

case "$FORMAT" in
    table)
        cc_banner
        echo
        cc_storage_inventory_output table
        ;;
    csv|markdown)
        cc_storage_inventory_output "$FORMAT"
        ;;
esac
