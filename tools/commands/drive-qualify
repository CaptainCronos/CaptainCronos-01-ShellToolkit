#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-qualify
# Version     : 1.1.0-alpha1
# Category    : Storage
# Requires    : bash smartctl awk grep date mkdir tee
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Run non-destructive drive qualification workflow.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-config.sh"
source "$PROJECT_ROOT/lib/cc-assets.sh"
source "$PROJECT_ROOT/lib/cc-yaml.sh"
source "$PROJECT_ROOT/lib/cc-smart.sh"
source "$PROJECT_ROOT/lib/cc-storage.sh"
source "$PROJECT_ROOT/lib/cc-report.sh"

DEVICE=""
MODE="start"
START_LONG="no"
QUAL_ROOT="$(cc_report_root)/drives/qualification"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-qualify start [--long] /dev/sdX
  cc drive-qualify status /dev/sdX
  cc drive-qualify complete /dev/sdX
  cc drive-qualify /dev/sdX

Actions:
  start     Capture pre-test report, start short SMART self-test, and optionally start long self-test.
  status    Show SMART self-test status.
  complete  Capture final report and mark asset qualified when SMART result is GOOD.

Options:
  --long    Start a SMART long self-test after the initial report instead of only a short self-test.

Notes:
  This is non-destructive. It does not run write/read burn-in.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h) usage; exit 0 ;;
        --version) echo "1.1.0-alpha1"; exit 0 ;;
        start|status|complete) MODE="$1"; shift ;;
        --long) START_LONG="yes"; shift ;;
        *) DEVICE="$1"; shift ;;
    esac
done

[ -n "$DEVICE" ] || { usage; exit 1; }
cc_storage_require_smartctl || exit $?
cc_storage_require_device "$DEVICE" || exit $?

safe_name="$(cc_storage_device_basename "$DEVICE")"
qual_dir="$(cc_report_make_dir "drives/qualification" "$safe_name")"

latest_asset_for_device() {
    local dev="$1" file
    cc_assets_init
    for file in "$(cc_asset_dir drives)"/*.yaml; do
        [ -f "$file" ] || continue
        if grep -q "current_device: \"$dev\"" "$file"; then
            echo "$file"
            return 0
        fi
    done
    echo ""
}

write_qualification_note() {
    local file="$1" status="$2" report="$3"
    [ -f "$file" ] || return 0
    cc_yaml_set "$file" qualified "$status"
    cc_yaml_set "$file" qualified_date "$(date +%Y-%m-%d)"
    cc_yaml_set "$file" last_qualification_report "$report"
    if [ "$status" = "yes" ]; then
        cc_yaml_set "$file" state "qualified"
        cc_asset_append_history drives "$(cc_yaml_get "$file" asset_id)" "state:qualified" "qualification report=$report"
    else
        cc_yaml_set "$file" state "watch"
        cc_asset_append_history drives "$(cc_yaml_get "$file" asset_id)" "state:watch" "qualification review required report=$report"
    fi
}

write_start_readme() {
    local file="$1"
    cc_report_write_metadata "$file" "Drive Qualification Started" "$DEVICE"
    cc_report_append_kv "$file" "Device" "$DEVICE"
    cc_report_append_kv "$file" "Long test requested" "$START_LONG"
    {
        echo
        echo "Next commands:"
        echo "  cc drive-qualify status $DEVICE"
        echo "  cc drive-qualify complete $DEVICE"
    } >> "$file"
}

write_final_report() {
    local file="$1" result="$2" recommendation="$3" asset_file="$4"
    cc_report_write_metadata "$file" "Drive Qualification Report" "$DEVICE"
    cc_report_append_kv "$file" "Device" "$DEVICE"
    cc_report_append_kv "$file" "Result" "$result"
    cc_report_append_kv "$file" "Recommendation" "$recommendation"
    cc_report_append_kv "$file" "Asset" "${asset_file:-not found}"
}

case "$MODE" in
    start)
        mkdir -p "$qual_dir"
        cc_banner
        cc_log "Starting non-destructive drive qualification for $DEVICE"
        cc_log "Qualification directory: $qual_dir"
        echo
        bash "$PROJECT_ROOT/tools/cc" drive-report "$DEVICE" | tee "$qual_dir/precheck-summary.txt"
        cc_storage_test_start "$DEVICE" short | tee "$qual_dir/short-test-start.txt" || true
        if [ "$START_LONG" = "yes" ]; then
            cc_storage_test_start "$DEVICE" long | tee "$qual_dir/long-test-start.txt" || true
        fi
        write_start_readme "$qual_dir/README.txt"
        echo
        cc_log "Qualification started. Check later with: cc drive-qualify status $DEVICE"
        ;;
    status)
        cc_storage_test_status "$DEVICE"
        ;;
    complete)
        mkdir -p "$qual_dir"
        cc_banner
        cc_log "Completing non-destructive drive qualification for $DEVICE"
        cc_log "Final qualification directory: $qual_dir"
        echo
        bash "$PROJECT_ROOT/tools/cc" drive-report "$DEVICE" | tee "$qual_dir/final-summary.txt"
        result="$(cc_smart_extract_result "$qual_dir/final-summary.txt")"
        [ -n "$result" ] || result="UNKNOWN"
        if [ "$result" = "GOOD" ]; then
            recommendation="APPROVED FOR SERVICE"
            asset_status="yes"
        else
            recommendation="REVIEW REQUIRED"
            asset_status="review"
        fi
        asset_file="$(latest_asset_for_device "$DEVICE")"
        write_qualification_note "$asset_file" "$asset_status" "$qual_dir"
        write_final_report "$qual_dir/QUALIFICATION.txt" "$result" "$recommendation" "$asset_file"
        echo
        cat "$qual_dir/QUALIFICATION.txt"
        ;;
esac
