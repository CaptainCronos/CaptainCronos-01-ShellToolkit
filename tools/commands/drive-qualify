#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-qualify
# Version     : 1.0.0-alpha1
# Category    : Storage
# Requires    : bash smartctl awk grep sed date mkdir
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Run non-destructive drive qualification workflow.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-config.sh"
source "$PROJECT_ROOT/lib/cc-assets.sh"

DEVICE=""
MODE="start"
START_LONG="no"
REPORT_ROOT="$(cc_config_get REPORT_DIR "$HOME/.captaincronos/reports")/drives"
QUAL_ROOT="$REPORT_ROOT/qualification"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-qualify start [--long] /dev/sdX
  cc drive-qualify status /dev/sdX
  cc drive-qualify complete /dev/sdX
  cc drive-qualify /dev/sdX

Actions:
  start     Capture pre-test report, start short SMART test, and optionally start long test.
  status    Show SMART self-test status.
  complete  Capture final report and mark asset qualified when SMART result is GOOD.

Options:
  --long    Start a SMART long test after the initial report instead of only a short test.

Notes:
  This is non-destructive. It does not run badblocks or write/read burn-in.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.0.0-alpha1"
            exit 0
            ;;
        start|status|complete)
            MODE="$1"
            shift
            ;;
        --long)
            START_LONG="yes"
            shift
            ;;
        *)
            DEVICE="$1"
            shift
            ;;
    esac
done

[ -n "$DEVICE" ] || { usage; exit 1; }
[ -e "$DEVICE" ] || { cc_error "Device not found: $DEVICE"; exit 1; }

if ! command -v smartctl >/dev/null 2>&1; then
    cc_error "smartctl not found. Install smartmontools."
    exit 1
fi

safe_name="$(basename "$DEVICE")"
stamp="$(date +%Y%m%d-%H%M%S)"
qual_dir="$QUAL_ROOT/${safe_name}-${stamp}"

latest_asset_for_device() {
    local dev="$1" file
    cc_assets_init
    for file in "$(cc_asset_dir drives)"/*.yaml; do
        [ -f "$file" ] || continue
        if grep -q "current_device: \"$dev\"" "$file"; then
            echo "$file"
            return 0
        fi
    done
    echo ""
}

summary_value() {
    local file="$1" key="$2"
    awk -F: -v key="$key" '$1 ~ key {sub(/^[ \t]+/, "", $2); print $2; exit}' "$file"
}

write_qualification_note() {
    local file="$1" status="$2" report="$3"
    [ -f "$file" ] || return 0
    tmp="${file}.tmp.$$"
    awk -v status="$status" -v report="$report" '
        /^qualified:/ {print "qualified: \"" status "\""; next}
        /^qualified_date:/ {print "qualified_date: \"" strftime("%Y-%m-%d") "\""; next}
        /^last_qualification_report:/ {seen=1; print "last_qualification_report: \"" report "\""; next}
        {print}
        END {if (!seen) print "last_qualification_report: \"" report "\""}
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

case "$MODE" in
    start)
        mkdir -p "$qual_dir"
        cc_banner
        cc_log "Starting non-destructive drive qualification for $DEVICE"
        cc_log "Qualification directory: $qual_dir"
        echo
        bash "$PROJECT_ROOT/tools/cc" drive-report "$DEVICE" | tee "$qual_dir/precheck-summary.txt"
        bash "$PROJECT_ROOT/tools/cc" drive-test short "$DEVICE" | tee "$qual_dir/short-test-start.txt" || true
        if [ "$START_LONG" = "yes" ]; then
            bash "$PROJECT_ROOT/tools/cc" drive-test long "$DEVICE" | tee "$qual_dir/long-test-start.txt" || true
        fi
        {
            echo "Drive Qualification Started"
            echo "Device: $DEVICE"
            echo "Started: $(date)"
            echo "Long test requested: $START_LONG"
            echo
            echo "Next commands:"
            echo "  cc drive-qualify status $DEVICE"
            echo "  cc drive-qualify complete $DEVICE"
        } > "$qual_dir/README.txt"
        echo
        cc_log "Qualification started. Check later with: cc drive-qualify status $DEVICE"
        ;;
    status)
        bash "$PROJECT_ROOT/tools/cc" drive-test status "$DEVICE"
        ;;
    complete)
        mkdir -p "$qual_dir"
        cc_banner
        cc_log "Completing non-destructive drive qualification for $DEVICE"
        cc_log "Final qualification directory: $qual_dir"
        echo
        bash "$PROJECT_ROOT/tools/cc" drive-report "$DEVICE" | tee "$qual_dir/final-summary.txt"
        result="$(summary_value "$qual_dir/final-summary.txt" '^Result')"
        [ -n "$result" ] || result="UNKNOWN"
        if [ "$result" = "GOOD" ]; then
            recommendation="APPROVED FOR SERVICE"
            asset_status="yes"
        else
            recommendation="REVIEW REQUIRED"
            asset_status="review"
        fi
        asset_file="$(latest_asset_for_device "$DEVICE")"
        write_qualification_note "$asset_file" "$asset_status" "$qual_dir"
        {
            echo "Drive Qualification Report"
            echo "Generated: $(date)"
            echo "Device: $DEVICE"
            echo "Result: $result"
            echo "Recommendation: $recommendation"
            echo "Asset: ${asset_file:-not found}"
        } > "$qual_dir/QUALIFICATION.txt"
        echo
        cat "$qual_dir/QUALIFICATION.txt"
        ;;
esac
