#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-test
# Version     : 1.1.0-alpha1
# Category    : Storage
# Requires    : bash smartctl awk grep
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Start or inspect SMART self-tests for one storage device.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-smart.sh"
source "$PROJECT_ROOT/lib/cc-storage.sh"

ACTION="status"
DEVICE=""

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-test status /dev/sdX
  cc drive-test short  /dev/sdX
  cc drive-test long   /dev/sdX
  cc drive-test abort  /dev/sdX

Actions:
  status   Show SMART self-test status and recent self-test log.
  short    Start SMART short self-test.
  long     Start SMART long self-test.
  abort    Abort handling remains in the command wrapper for compatibility.

Notes:
  Starting tests may require sudo.
  This command does not run destructive write/read burn-in tests.
EOF_HELP
}

case "${1:-}" in
    --help|-h) usage; exit 0 ;;
    --version) echo "1.1.0-alpha1"; exit 0 ;;
    status|short|long|abort)
        ACTION="$1"
        shift
        ;;
esac

DEVICE="${1:-}"
[ -n "$DEVICE" ] || { usage; exit 1; }

cc_storage_require_smartctl || exit $?
cc_storage_require_device "$DEVICE" || exit $?

case "$ACTION" in
    status) cc_storage_test_status "$DEVICE" ;;
    short) cc_storage_test_start "$DEVICE" short ;;
    long) cc_storage_test_start "$DEVICE" long ;;
    abort)
        cc_warn "Abort is preserved for compatibility; use smartctl directly if this system requires privileged cancellation."
        ;;
esac
