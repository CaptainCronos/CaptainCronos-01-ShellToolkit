#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-burnin
# Version     : 0.2.0-alpha1
# Category    : Storage
# Requires    : bash smartctl date mkdir
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Framework for drive acceptance workflow.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-config.sh"
source "$PROJECT_ROOT/lib/cc-smart.sh"
source "$PROJECT_ROOT/lib/cc-storage.sh"

ACTION="plan"
DEVICE=""

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-burnin plan /dev/sdX
  cc drive-burnin start /dev/sdX
  cc drive-burnin status /dev/sdX

Phase 1 framework only.

Actions:
  plan    Show the intended drive acceptance workflow.
  start   Capture initial report and start non-destructive qualification.
  status  Show current SMART self-test status.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h) usage; exit 0 ;;
        --version) echo "0.2.0-alpha1"; exit 0 ;;
        plan|start|status) ACTION="$1"; shift ;;
        *) DEVICE="$1"; shift ;;
    esac
done

[ -n "$DEVICE" ] || { usage; exit 1; }
cc_storage_require_device "$DEVICE" || exit $?

show_plan() {
    cc_banner
    echo
    echo "Drive acceptance plan"
    echo "---------------------"
    printf '%-14s %s\n' "Device:" "$DEVICE"
    echo
    echo "Current Phase 1 workflow:"
    echo "  1. Verify target device exists."
    echo "  2. Capture initial drive report."
    echo "  3. Start non-destructive SMART qualification."
    echo "  4. Monitor SMART self-test status."
    echo "  5. Complete qualification and update asset record."
    echo
    echo "Commands:"
    echo "  cc drive-burnin start $DEVICE"
    echo "  cc drive-burnin status $DEVICE"
    echo "  cc drive-qualify complete $DEVICE"
}

start_workflow() {
    cc_banner
    echo
    cc_log "Starting Phase 1 drive acceptance workflow for $DEVICE"
    echo
    bash "$PROJECT_ROOT/tools/cc" drive-report "$DEVICE"
    echo
    bash "$PROJECT_ROOT/tools/cc" drive-qualify start "$DEVICE"
    echo
    cc_log "Monitor with: cc drive-burnin status $DEVICE"
}

case "$ACTION" in
    plan) show_plan ;;
    start) start_workflow ;;
    status)
        cc_storage_require_smartctl || exit $?
        cc_storage_test_status "$DEVICE"
        ;;
esac
