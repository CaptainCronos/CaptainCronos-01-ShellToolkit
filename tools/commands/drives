#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drives
# Version     : reads VERSION
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Show installed storage devices and mount information.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/bash/bash_functions"

case "${1:-}" in
    --help|-h)
        echo "Usage: cc drives"
        echo
        echo "Shows block devices, filesystems, labels, UUIDs, usage, and mount points."
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

if declare -F findharddrives >/dev/null 2>&1; then
    findharddrives
else
    lsblk -e 7 -o NAME,TYPE,SIZE,FSTYPE,LABEL,UUID,FSUSE%,MOUNTPOINTS
fi
