#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drives
# Version     : reads VERSION
# Category    : Storage
# Requires    : bash lsblk df awk
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Show installed storage devices and mount information.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

case "${1:-}" in
    --help|-h)
        echo "Usage: cc drives"
        echo
        echo "Shows physical block devices, filesystems, labels, UUIDs, usage, and mount points."
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

cc_banner

echo
echo "Block Devices"
echo "-------------"
lsblk -e 7 -o NAME,TYPE,SIZE,FSTYPE,LABEL,UUID,FSUSE%,MOUNTPOINTS

echo
echo "Filesystem Usage"
echo "----------------"
df -hT | awk 'NR==1 || /^\/dev\//'
