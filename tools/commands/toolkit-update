#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : toolkit-update
# Version     : reads VERSION
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Pull latest toolkit changes and reinstall local command files.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

case "${1:-}" in
    --help|-h)
        echo "Usage: cc toolkit-update [install/update.sh options]"
        echo
        echo "Pulls latest toolkit changes and runs the toolkit update workflow."
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

exec install/update.sh "$@"
