#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : asset
# Version     : 1.0.0-alpha1
# Category    : Core
# Requires    : bash find cat mkdir
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Manage local lifecycle asset inventory records.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-assets.sh"

ACTION="list"
TYPE=""
NAME=""

usage() {
    cat <<'EOF_HELP'
Usage:
  cc asset init
  cc asset list [TYPE]
  cc asset show TYPE NAME
  cc asset path [TYPE]

Types:
  drives
  systems
  repositories
  licenses
  purchases

Examples:
  cc asset init
  cc asset list drives
  cc asset path drives
  cc asset show drives SERIAL.yaml
EOF_HELP
}

if [ "$#" -gt 0 ]; then
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.0.0-alpha1"
            exit 0
            ;;
        init|list|show|path)
            ACTION="$1"
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
fi

TYPE="${1:-}"
NAME="${2:-}"

case "$ACTION" in
    init)
        cc_assets_init
        cc_log "Asset inventory initialized: $(cc_assets_root)"
        ;;
    path)
        cc_assets_init
        if [ -n "$TYPE" ]; then
            echo "$(cc_asset_dir "$TYPE")"
        else
            echo "$(cc_assets_root)"
        fi
        ;;
    list)
        cc_assets_init
        if [ -n "$TYPE" ]; then
            if [ ! -d "$(cc_asset_dir "$TYPE")" ]; then
                cc_error "Asset type not found: $TYPE"
                exit 1
            fi
            cc_asset_list "$TYPE"
        else
            find "$(cc_assets_root)" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
        fi
        ;;
    show)
        [ -n "$TYPE" ] || { usage; exit 1; }
        [ -n "$NAME" ] || { usage; exit 1; }
        file="$(cc_asset_dir "$TYPE")/$NAME"
        [ -f "$file" ] || { cc_error "Asset not found: $file"; exit 1; }
        cat "$file"
        ;;
esac
