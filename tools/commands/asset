#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : asset
# Version     : 1.2.0-alpha1
# Category    : Core
# Requires    : bash find cat mkdir awk grep sed date
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Manage local lifecycle asset inventory records.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-environment.sh"
cc_env_export || true
source "$PROJECT_ROOT/lib/cc-assets.sh"

ACTION="list"
TYPE=""
NAME=""

usage() {
    cat <<'EOF_HELP'
Usage:
  cc asset init
  cc asset list [TYPE]
  cc asset show TYPE NAME
  cc asset path [TYPE]
  cc asset search TYPE QUERY
  cc asset inventory TYPE
  cc asset create TYPE NAME [key=value ...]
  cc asset set TYPE NAME key=value [key=value ...]
  cc asset state TYPE NAME STATE [NOTE]
  cc asset history TYPE NAME
  cc asset retire TYPE NAME [NOTE]
  cc asset export [TYPE]

Types:
  drives
  systems
  repositories
  licenses
  purchases

Lifecycle states:
  new inventory testing qualified production watch failed retired

Examples:
  cc asset init
  cc asset list drives
  cc asset create drives SERIAL model=TEAM size=8TB state=new
  cc asset state drives SERIAL qualified "Passed SMART long test"
  cc asset history drives SERIAL
  cc asset retire drives SERIAL "Removed from service"
EOF_HELP
}

if [ "$#" -gt 0 ]; then
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.2.0-alpha1"
            exit 0
            ;;
        init|list|show|path|search|inventory|set|create|state|history|retire|export)
            ACTION="$1"
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
fi

TYPE="${1:-}"
NAME="${2:-}"

valid_state() {
    case "$1" in
        new|inventory|testing|qualified|production|watch|failed|retired) return 0 ;;
        *) return 1 ;;
    esac
}

asset_file_path() {
    local type="$1" name="$2"
    if [ -f "$(cc_asset_dir "$type")/$name" ]; then
        echo "$(cc_asset_dir "$type")/$name"
    elif [ -f "$(cc_asset_dir "$type")/$name.yaml" ]; then
        echo "$(cc_asset_dir "$type")/$name.yaml"
    else
        cc_asset_file "$type" "$name"
    fi
}

yaml_value() {
    local file="$1" key="$2"
    awk -F: -v key="$key" '$1 == key {sub(/^[ \t]+/, "", $2); gsub(/^"|"$/, "", $2); print $2; exit}' "$file"
}

yaml_nested_value() {
    local file="$1" section="$2" key="$3"
    awk -F: -v section="$section" -v key="$key" '
        $1 == section {inside=1; next}
        inside && /^[^ ]/ {inside=0}
        inside && $1 ~ "^[ ]+" key "$" {sub(/^[ \t]+/, "", $2); gsub(/^"|"$/, "", $2); print $2; exit}
    ' "$file"
}

set_yaml_value() {
    local file="$1" key="$2" value="$3" tmp
    tmp="${file}.tmp.$$"
    awk -v key="$key" -v value="$value" '
        BEGIN {found=0}
        $0 ~ "^" key ":" {print key ": \"" value "\""; found=1; next}
        {print}
        END {if (!found) print key ": \"" value "\""}
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

set_nested_yaml_value() {
    local file="$1" section="$2" key="$3" value="$4" tmp
    tmp="${file}.tmp.$$"
    awk -v section="$section" -v key="$key" -v value="$value" '
        BEGIN {inside=0; section_seen=0; key_set=0}
        $0 == section ":" {inside=1; section_seen=1; print; next}
        inside && /^[^ ]/ {
            if (!key_set) {print "  " key ": \"" value "\""; key_set=1}
            inside=0
        }
        inside && $0 ~ "^[ ]+" key ":" {print "  " key ": \"" value "\""; key_set=1; next}
        {print}
        END {
            if (!section_seen) {
                print section ":"
                print "  " key ": \"" value "\""
            } else if (inside && !key_set) {
                print "  " key ": \"" value "\""
            }
        }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

create_asset() {
    local type="$1" name="$2" file pair key value
    [ -n "$type" ] || { usage; exit 1; }
    [ -n "$name" ] || { usage; exit 1; }
    cc_assets_init
    file="$(asset_file_path "$type" "$name")"
    [ ! -f "$file" ] || { cc_error "Asset already exists: $file"; exit 1; }
    cat > "$file" <<EOF_ASSET
asset_id: "$name"
type: "$type"
state: "new"
created: "$(cc_asset_timestamp)"
updated: "$(cc_asset_timestamp)"
host_id: "${CC_HOST_ID:-unknown}"
notes: ""
EOF_ASSET
    shift 2 || true
    for pair in "$@"; do
        key="${pair%%=*}"
        value="${pair#*=}"
        [ "$key" != "$value" ] || { cc_error "Expected key=value: $pair"; exit 1; }
        set_yaml_value "$file" "$key" "$value"
    done
    cc_asset_append_history "$type" "$name" "create" "asset created"
    cc_log "Created asset: $file"
}

set_asset_pairs() {
    local type="$1" name="$2" file pair key value subkey
    [ -n "$type" ] || { usage; exit 1; }
    [ -n "$name" ] || { usage; exit 1; }
    file="$(asset_file_path "$type" "$name")"
    [ -f "$file" ] || { cc_error "Asset not found: $file"; exit 1; }
    shift 2 || true
    [ "$#" -gt 0 ] || { usage; exit 1; }
    for pair in "$@"; do
        key="${pair%%=*}"
        value="${pair#*=}"
        [ "$key" != "$value" ] || { cc_error "Expected key=value: $pair"; exit 1; }
        case "$key" in
            location.*)
                subkey="${key#location.}"
                set_nested_yaml_value "$file" location "$subkey" "$value"
                ;;
            *)
                set_yaml_value "$file" "$key" "$value"
                ;;
        esac
        cc_log "Set $key"
    done
    set_yaml_value "$file" updated "$(cc_asset_timestamp)"
    cc_asset_append_history "$type" "$name" "set" "$*"
}

set_asset_state() {
    local type="$1" name="$2" state="$3" note="${4:-}" file
    [ -n "$type" ] || { usage; exit 1; }
    [ -n "$name" ] || { usage; exit 1; }
    [ -n "$state" ] || { usage; exit 1; }
    valid_state "$state" || { cc_error "Invalid state: $state"; exit 1; }
    file="$(asset_file_path "$type" "$name")"
    [ -f "$file" ] || { cc_error "Asset not found: $file"; exit 1; }
    set_yaml_value "$file" state "$state"
    set_yaml_value "$file" updated "$(cc_asset_timestamp)"
    cc_asset_append_history "$type" "$name" "state:$state" "$note"
    cc_log "Asset state set: $state"
}

case "$ACTION" in
    init)
        cc_assets_init
        cc_log "Asset inventory initialized: $(cc_assets_root)"
        ;;
    path)
        cc_assets_init
        if [ -n "$TYPE" ]; then echo "$(cc_asset_dir "$TYPE")"; else echo "$(cc_assets_root)"; fi
        ;;
    list)
        cc_assets_init
        if [ -n "$TYPE" ]; then
            [ -d "$(cc_asset_dir "$TYPE")" ] || { cc_error "Asset type not found: $TYPE"; exit 1; }
            cc_asset_list "$TYPE"
        else
            find "$(cc_assets_root)" -mindepth 1 -maxdepth 1 -type d ! -name '.history' -printf '%f\n' | sort
        fi
        ;;
    show)
        [ -n "$TYPE" ] || { usage; exit 1; }
        [ -n "$NAME" ] || { usage; exit 1; }
        file="$(asset_file_path "$TYPE" "$NAME")"
        [ -f "$file" ] || { cc_error "Asset not found: $file"; exit 1; }
        cat "$file"
        ;;
    search)
        [ -n "$TYPE" ] || { usage; exit 1; }
        query="${2:-}"
        [ -n "$query" ] || { usage; exit 1; }
        grep -Ril -- "$query" "$(cc_asset_dir "$TYPE")" 2>/dev/null | sort || true
        ;;
    inventory)
        [ -n "$TYPE" ] || { usage; exit 1; }
        if [ "$TYPE" = "drives" ]; then
            printf '%-24s %-24s %-12s %-12s %-8s %-10s %s\n' "Serial" "Model" "State" "Qualified" "Bay" "Pool" "Device"
            printf '%-24s %-24s %-12s %-12s %-8s %-10s %s\n' "------" "-----" "-----" "---------" "---" "----" "------"
            cc_asset_list drives | while read -r file; do
                [ -f "$file" ] || continue
                serial="$(yaml_value "$file" serial)"; [ -n "$serial" ] || serial="$(yaml_value "$file" asset_id)"
                model="$(yaml_value "$file" model)"
                state="$(yaml_value "$file" state)"
                qualified="$(yaml_value "$file" qualified)"
                device="$(yaml_value "$file" current_device)"
                bay="$(yaml_nested_value "$file" location bay)"
                pool="$(yaml_nested_value "$file" location pool)"
                printf '%-24s %-24s %-12s %-12s %-8s %-10s %s\n' "$serial" "$model" "$state" "$qualified" "$bay" "$pool" "$device"
            done
        else
            cc_asset_list "$TYPE"
        fi
        ;;
    create)
        create_asset "$@"
        ;;
    set)
        set_asset_pairs "$@"
        ;;
    state)
        set_asset_state "$TYPE" "$NAME" "${3:-}" "${4:-}"
        ;;
    retire)
        set_asset_state "$TYPE" "$NAME" retired "${3:-retired}"
        ;;
    history)
        [ -n "$TYPE" ] || { usage; exit 1; }
        [ -n "$NAME" ] || { usage; exit 1; }
        file="$(cc_asset_history_file "$TYPE" "$NAME")"
        [ -f "$file" ] || { cc_warn "No history found: $file"; exit 0; }
        cat "$file"
        ;;
    export)
        cc_assets_init
        if [ -n "$TYPE" ]; then
            find "$(cc_asset_dir "$TYPE")" -maxdepth 1 -type f -print -exec cat {} \;
        else
            find "$(cc_assets_root)" -type f | sort
        fi
        ;;
esac
