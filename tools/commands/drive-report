#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-report
# Version     : 1.0.0-alpha1
# Category    : Storage
# Requires    : bash smartctl date mkdir
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Save SMART and inventory reports for one storage device.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-config.sh"

DEVICE=""
REPORT_ROOT="$(cc_config_get REPORT_DIR "$HOME/.captaincronos/reports")/drives"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-report /dev/sdX
  cc drive-report /dev/nvme0n1

Creates an archived drive report under:
  ~/.captaincronos/reports/drives/

Report contents:
  summary.txt      concise drive SMART summary
  smartctl-a.txt   full smartctl -a output
  metadata.txt     report metadata
EOF_HELP
}

case "${1:-}" in
    --help|-h)
        usage
        exit 0
        ;;
    --version)
        echo "1.0.0-alpha1"
        exit 0
        ;;
esac

DEVICE="${1:-}"
[ -n "$DEVICE" ] || { usage; exit 1; }
[ -e "$DEVICE" ] || { cc_error "Device not found: $DEVICE"; exit 1; }

if ! command -v smartctl >/dev/null 2>&1; then
    cc_error "smartctl not found. Install smartmontools."
    exit 1
fi

safe_name="$(basename "$DEVICE" | tr '/' '_')"
stamp="$(date +%Y%m%d-%H%M%S)"
out_dir="$REPORT_ROOT/${safe_name}-${stamp}"
mkdir -p "$out_dir"

{
    echo "Captain Cronos Drive Report"
    echo "Generated: $(date)"
    echo "Device: $DEVICE"
    echo "Host: $(hostname 2>/dev/null || echo unknown)"
    echo "Kernel: $(uname -r 2>/dev/null || echo unknown)"
} > "$out_dir/metadata.txt"

bash "$PROJECT_ROOT/tools/cc" drive-smart "$DEVICE" > "$out_dir/summary.txt" 2>&1 || true
sudo smartctl -a "$DEVICE" > "$out_dir/smartctl-a.txt" 2>&1 || smartctl -a "$DEVICE" > "$out_dir/smartctl-a.txt" 2>&1 || true

cc_log "Drive report created: $out_dir"
echo
cat "$out_dir/summary.txt"
