#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : drive-report
# Version     : 1.3.0-alpha1
# Category    : Storage
# Requires    : bash smartctl date mkdir awk grep hostname uname mv
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Save SMART reports and update drive asset records.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"
source "$PROJECT_ROOT/lib/cc-environment.sh"
cc_env_export || true
source "$PROJECT_ROOT/lib/cc-config.sh"
source "$PROJECT_ROOT/lib/cc-assets.sh"
source "$PROJECT_ROOT/lib/cc-yaml.sh"
source "$PROJECT_ROOT/lib/cc-smart.sh"

DEVICE=""
REPORT_ROOT="${CC_REPORT_DIR:-$(cc_config_get REPORT_DIR "$HOME/.captaincronos/reports")}/drives"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc drive-report /dev/sdX
  cc drive-report /dev/nvme0n1

Creates an archived drive report under the host report directory.
Also creates/updates a drive asset record and appends asset history.
EOF_HELP
}

case "${1:-}" in
    --help|-h) usage; exit 0 ;;
    --version) echo "1.3.0-alpha1"; exit 0 ;;
esac

DEVICE="${1:-}"
[ -n "$DEVICE" ] || { usage; exit 1; }
[ -e "$DEVICE" ] || { cc_error "Device not found: $DEVICE"; exit 1; }

if ! command -v smartctl >/dev/null 2>&1; then
    cc_error "smartctl not found. Install smartmontools."
    exit 127
fi

safe_name="$(basename "$DEVICE" | tr '/' '_')"
stamp="$(date +%Y%m%d-%H%M%S)"
out_dir="$REPORT_ROOT/${safe_name}-${stamp}"
mkdir -p "$out_dir"
cc_assets_init

{
    echo "Captain Cronos Drive Report"
    echo "Generated: $(date)"
    echo "Device: $DEVICE"
    echo "Host ID: ${CC_HOST_ID:-unknown}"
    echo "Host: $(hostname 2>/dev/null || echo unknown)"
    echo "Kernel: $(uname -r 2>/dev/null || echo unknown)"
} > "$out_dir/metadata.txt"

bash "$PROJECT_ROOT/tools/cc" drive-smart "$DEVICE" > "$out_dir/summary.txt" 2>&1 || true
sudo smartctl -a "$DEVICE" > "$out_dir/smartctl-a.txt" 2>&1 || smartctl -a "$DEVICE" > "$out_dir/smartctl-a.txt" 2>&1 || true

model="$(cc_smart_extract_model "$out_dir/summary.txt")"
serial="$(cc_smart_extract_serial "$out_dir/summary.txt")"
size="$(cc_smart_extract_size "$out_dir/summary.txt")"
hours="$(cc_smart_extract_hours "$out_dir/summary.txt")"
temp="$(cc_smart_extract_temp "$out_dir/summary.txt")"
smart="$(cc_smart_extract_status "$out_dir/summary.txt")"
result="$(cc_smart_extract_result "$out_dir/summary.txt")"

[ -n "$serial" ] || serial="$safe_name"
asset_file="$(cc_asset_file drives "$serial")"
state="inventory"
qualified="unknown"
created="$(cc_asset_timestamp)"

if [ -f "$asset_file" ]; then
    current_state="$(cc_yaml_get "$asset_file" state)"
    current_created="$(cc_yaml_get "$asset_file" created)"
    current_qualified="$(cc_yaml_get "$asset_file" qualified)"
    [ -n "$current_state" ] && state="$current_state"
    [ -n "$current_created" ] && created="$current_created"
    [ -n "$current_qualified" ] && qualified="$current_qualified"
fi

cat > "$asset_file" <<EOF_ASSET
asset_id: "$serial"
type: "drives"
asset_type: "drive"
state: "$state"
created: "$created"
updated: "$(cc_asset_timestamp)"
host_id: "${CC_HOST_ID:-unknown}"
serial: "$serial"
model: "$model"
size: "$size"
current_device: "$DEVICE"
last_seen: "$(cc_asset_timestamp)"
host: "$(hostname 2>/dev/null || echo unknown)"
smart: "$smart"
result: "$result"
power_on_hours: "$hours"
temperature: "$temp"
last_report: "$out_dir"
qualified: "$qualified"
qualified_date: ""
location:
  system: "$(hostname 2>/dev/null || echo unknown)"
  bay: "$( [ -f "$asset_file" ] && cc_yaml_get_nested "$asset_file" location bay || true )"
  pool: "$( [ -f "$asset_file" ] && cc_yaml_get_nested "$asset_file" location pool || true )"
notes: "Asset record created or updated by cc drive-report."
EOF_ASSET

cc_asset_append_history drives "$serial" "report" "device=$DEVICE result=$result smart=$smart report=$out_dir"

cc_log "Drive report created: $out_dir"
cc_log "Drive asset updated: $asset_file"
cc_log "Drive asset history updated: $(cc_asset_history_file drives "$serial")"
echo
cat "$out_dir/summary.txt"
