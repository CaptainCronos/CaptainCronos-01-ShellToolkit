#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : monthly-health-timer
# Version     : reads VERSION
# Category    : Maintenance
# Requires    : bash systemctl
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Retire or inspect the standalone monthly health user timer.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

SERVICE_NAME="captaincronos-monthly-health.service"
TIMER_NAME="captaincronos-monthly-health.timer"
UNIT_DIR="$HOME/.config/systemd/user"

usage() {
    echo "Usage: cc monthly-health-timer status|retire|run-once|install-standalone|enable|disable"
    echo
    echo "Recommended architecture: run cc monthly-health from the existing daily-backup-report framework."
    echo "The standalone user timer is retained only as an optional fallback."
}

install_standalone() {
    mkdir -p "$UNIT_DIR"
    cp -f "$PROJECT_ROOT/templates/systemd/user/$SERVICE_NAME" "$UNIT_DIR/$SERVICE_NAME"
    cp -f "$PROJECT_ROOT/templates/systemd/user/$TIMER_NAME" "$UNIT_DIR/$TIMER_NAME"
    systemctl --user daemon-reload
    systemctl --user enable --now "$TIMER_NAME"
    cc_warn "Standalone timer installed. Prefer daily-backup-report integration when available."
}

retire_timer() {
    systemctl --user disable --now "$TIMER_NAME" 2>/dev/null || true
    rm -f "$UNIT_DIR/$TIMER_NAME" "$UNIT_DIR/$SERVICE_NAME"
    systemctl --user daemon-reload
    cc_log "Standalone monthly-health timer retired."
    cc_log "Use cc monthly-health manually or from daily-backup-report."
}

case "${1:-status}" in
    --help|-h)
        usage
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
    status)
        systemctl --user list-timers --all | grep -E 'NEXT|captaincronos-monthly-health' || true
        echo
        systemctl --user list-unit-files | grep -E 'captaincronos-monthly-health' || true
        ;;
    retire|remove|uninstall)
        retire_timer
        ;;
    run|run-once)
        bash "$PROJECT_ROOT/tools/cc" monthly-health
        ;;
    install|install-standalone)
        install_standalone
        ;;
    enable)
        systemctl --user enable --now "$TIMER_NAME"
        ;;
    disable)
        systemctl --user disable --now "$TIMER_NAME"
        ;;
    *)
        usage
        exit 1
        ;;
esac
