#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : update
# Version     : reads VERSION
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Pull latest changes and run the toolkit updater.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

case "${1:-}" in
    --help|-h)
        install/update.sh --help 2>/dev/null || {
            echo "Usage: cc update"
            echo
            echo "Pulls latest repository changes and runs update workflow."
        }
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

exec install/update.sh "$@"
