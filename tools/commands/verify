#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : verify
# Version     : reads VERSION
# Category    : Diagnostics
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Verify repository structure and Bash syntax.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

case "${1:-}" in
    --help|-h)
        echo "Usage: cc verify"
        echo
        echo "Runs the repository verification workflow."
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

install/verify.sh
