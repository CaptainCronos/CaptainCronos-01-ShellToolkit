#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : repos
# Version     : 1.2.0-alpha1
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Inventory and manage local Git repositories.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

ROOT="${CAPTAIN_CRONOS_GIT_ROOT:-$HOME/GitHub}"
ACTION="status"
APPLY=0
OUT=""
BUNDLE_DIR="${CAPTAIN_CRONOS_REPO_BUNDLE_DIR:-$HOME/.captaincronos/repo-bundles}"

usage() {
    cat <<'EOF_HELP'
Usage:
  cc repos [list|status|health|inventory|fetch|pull|sync|backup|verify|doctor] [options]

Options:
  --root PATH      Repository root. Default: ~/GitHub
  --out FILE       Output file for inventory. Supports .md and .csv
  --bundle-dir DIR Bundle output directory. Default: ~/.captaincronos/repo-bundles
  --apply          Apply mutating actions. Default is dry-run.

Actions:
  list       List detected Git repositories.
  status     Show repository dashboard with health, branch, state, sync, type, and origin.
  health     Show health-only dashboard and summary.
  inventory  Generate repository inventory table. Use --out to save.
  fetch      Fetch all remotes and prune stale refs. Dry-run by default.
  pull       Pull --ff-only for clean repositories. Dry-run by default.
  sync       Fetch then pull --ff-only for clean repositories. Dry-run by default.
  backup     Create git bundle backups for clean repositories. Dry-run by default.
  verify     Run cc verify for toolkit repositories that contain tools/cc.
  doctor     Run cc doctor for toolkit repositories that contain tools/cc.

Examples:
  cc repos
  cc repos status
  cc repos health
  cc repos inventory --out ~/repo-inventory.md
  cc repos inventory --out ~/repo-inventory.csv
  cc repos fetch --apply
  cc repos sync --apply
  cc repos backup --apply
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.2.0-alpha1"
            exit 0
            ;;
        --root)
            shift
            ROOT="${1:-}"
            [ -n "$ROOT" ] || { usage; exit 1; }
            shift
            ;;
        --out)
            shift
            OUT="${1:-}"
            [ -n "$OUT" ] || { usage; exit 1; }
            shift
            ;;
        --bundle-dir)
            shift
            BUNDLE_DIR="${1:-}"
            [ -n "$BUNDLE_DIR" ] || { usage; exit 1; }
            shift
            ;;
        --apply)
            APPLY=1
            shift
            ;;
        list|status|health|inventory|pull|fetch|sync|backup|verify|doctor)
            ACTION="$1"
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

find_repos() {
    find "$ROOT" -maxdepth 3 -type d -name .git 2>/dev/null | sed 's#/.git$##' | sort
}

repo_branch() {
    local branch
    branch="$(git -C "$1" branch --show-current 2>/dev/null || true)"
    [ -n "$branch" ] && echo "$branch" || echo detached
}

repo_origin() {
    git -C "$1" remote get-url origin 2>/dev/null || echo none
}

repo_state() {
    if [ -n "$(git -C "$1" status --short 2>/dev/null)" ]; then
        echo dirty
    else
        echo clean
    fi
}

repo_counts() {
    local repo="$1" upstream
    upstream="$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
    if [ -z "$upstream" ]; then
        echo "0 0 0"
        return 0
    fi
    git -C "$repo" rev-list --left-right --count HEAD..."$upstream" 2>/dev/null | awk '{print $1" "$2" 1}' || echo "0 0 0"
}

repo_ahead_behind() {
    local repo="$1" counts ahead behind upstream_flag
    counts="$(repo_counts "$repo")"
    ahead="$(echo "$counts" | awk '{print $1}')"
    behind="$(echo "$counts" | awk '{print $2}')"
    upstream_flag="$(echo "$counts" | awk '{print $3}')"
    if [ "$upstream_flag" = "0" ]; then
        echo "no-upstream"
    else
        echo "ahead:$ahead behind:$behind"
    fi
}

repo_last_commit() {
    git -C "$1" log -1 --format='%cs %h %s' 2>/dev/null || echo none
}

repo_size() {
    du -sh "$1" 2>/dev/null | awk '{print $1}'
}

repo_default_remote_branch() {
    git -C "$1" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#refs/remotes/origin/##' || echo unknown
}

repo_branch_counts() {
    local repo="$1" local_count remote_count
    local_count="$(git -C "$repo" branch --list 2>/dev/null | wc -l | tr -d ' ')"
    remote_count="$(git -C "$repo" branch -r 2>/dev/null | grep -v 'HEAD ->' | wc -l | tr -d ' ')"
    echo "local:$local_count remote:$remote_count"
}

repo_type() {
    local repo="$1" name
    name="$(basename "$repo")"
    if [ -x "$repo/tools/cc" ]; then
        echo "Toolkit"
    elif [ -f "$repo/docs/developer/CC-STD-001-Script-Header.md" ] || [[ "$name" == *Standards* ]]; then
        echo "Standards"
    elif [ -f "$repo/MASTER_ROADMAP.md" ]; then
        echo "Roadmap"
    elif [ -d "$repo/docs" ]; then
        echo "Docs"
    elif [ -f "$repo/package.json" ]; then
        echo "Node"
    elif [ -f "$repo/requirements.txt" ] || [ -d "$repo/src" ]; then
        echo "Python"
    else
        echo "General"
    fi
}

repo_health() {
    local repo="$1" score=100 branch state origin counts ahead behind upstream_flag
    branch="$(repo_branch "$repo")"
    state="$(repo_state "$repo")"
    origin="$(repo_origin "$repo")"
    counts="$(repo_counts "$repo")"
    ahead="$(echo "$counts" | awk '{print $1}')"
    behind="$(echo "$counts" | awk '{print $2}')"
    upstream_flag="$(echo "$counts" | awk '{print $3}')"

    [ "$state" = "dirty" ] && score=$((score - 25))
    [ "$branch" = "detached" ] && score=$((score - 20))
    [ "$origin" = "none" ] && score=$((score - 20))
    [ "$upstream_flag" = "0" ] && score=$((score - 15))
    [ "$ahead" -gt 0 ] 2>/dev/null && score=$((score - 10))
    [ "$behind" -gt 0 ] 2>/dev/null && score=$((score - 10))
    git -C "$repo" diff --name-only --diff-filter=U 2>/dev/null | grep -q . && score=$((score - 40))

    [ "$score" -lt 0 ] && score=0

    if [ "$score" -ge 90 ]; then
        echo "PASS:$score"
    elif [ "$score" -ge 70 ]; then
        echo "WARN:$score"
    else
        echo "FAIL:$score"
    fi
}

csv_escape() {
    printf '%s' "$1" | sed 's/"/""/g; s/^/"/; s/$/"/'
}

print_header() {
    cc_banner
    printf '%-14s %s\n' "Repo root:" "$ROOT"
    printf '%-14s %s\n' "Action:" "$ACTION"
    printf '%-14s %s\n' "Apply:" "$APPLY"
    [ -n "$OUT" ] && printf '%-14s %s\n' "Output:" "$OUT"
    echo
}

summary_footer() {
    local total=0 clean=0 dirty=0 pass=0 warn=0 fail=0 ahead_total=0 behind_total=0 toolkit=0 standards=0 docs=0 roadmap=0 other=0
    local repo state health type counts ahead behind
    while read -r repo; do
        [ -n "$repo" ] || continue
        total=$((total + 1))
        state="$(repo_state "$repo")"
        [ "$state" = "clean" ] && clean=$((clean + 1)) || dirty=$((dirty + 1))
        health="$(repo_health "$repo")"
        case "$health" in
            PASS:*) pass=$((pass + 1)) ;;
            WARN:*) warn=$((warn + 1)) ;;
            FAIL:*) fail=$((fail + 1)) ;;
        esac
        counts="$(repo_counts "$repo")"
        ahead="$(echo "$counts" | awk '{print $1}')"
        behind="$(echo "$counts" | awk '{print $2}')"
        [ "$ahead" -gt 0 ] 2>/dev/null && ahead_total=$((ahead_total + 1))
        [ "$behind" -gt 0 ] 2>/dev/null && behind_total=$((behind_total + 1))
        type="$(repo_type "$repo")"
        case "$type" in
            Toolkit) toolkit=$((toolkit + 1)) ;;
            Standards) standards=$((standards + 1)) ;;
            Docs) docs=$((docs + 1)) ;;
            Roadmap) roadmap=$((roadmap + 1)) ;;
            *) other=$((other + 1)) ;;
        esac
    done < <(find_repos)

    echo
    echo "Summary"
    echo "-------"
    printf '%-14s %s\n' "Repositories:" "$total"
    printf '%-14s %s\n' "Clean:" "$clean"
    printf '%-14s %s\n' "Dirty:" "$dirty"
    printf '%-14s %s\n' "PASS:" "$pass"
    printf '%-14s %s\n' "WARN:" "$warn"
    printf '%-14s %s\n' "FAIL:" "$fail"
    printf '%-14s %s\n' "Ahead:" "$ahead_total"
    printf '%-14s %s\n' "Behind:" "$behind_total"
    printf '%-14s %s\n' "Toolkit:" "$toolkit"
    printf '%-14s %s\n' "Standards:" "$standards"
    printf '%-14s %s\n' "Docs:" "$docs"
    printf '%-14s %s\n' "Roadmap:" "$roadmap"
    printf '%-14s %s\n' "Other:" "$other"
}

inventory_md() {
    echo "# Repository Inventory"
    echo
    echo "Generated: $(date)"
    echo "Root: $ROOT"
    echo
    echo "| Repository | Health | Type | Branch | Default | Branches | State | Sync | Origin | Last Commit | Size |"
    echo "|---|---|---|---|---|---|---|---|---|---|---|"
    while read -r repo; do
        [ -n "$repo" ] || continue
        echo "| $(basename "$repo") | $(repo_health "$repo") | $(repo_type "$repo") | $(repo_branch "$repo") | $(repo_default_remote_branch "$repo") | $(repo_branch_counts "$repo") | $(repo_state "$repo") | $(repo_ahead_behind "$repo") | $(repo_origin "$repo") | $(repo_last_commit "$repo" | sed 's/|/-/g') | $(repo_size "$repo") |"
    done < <(find_repos)
    summary_footer
}

inventory_csv() {
    echo "repository,path,health,type,branch,default_branch,branches,state,sync,origin,last_commit,size"
    while read -r repo; do
        [ -n "$repo" ] || continue
        printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
            "$(csv_escape "$(basename "$repo")")" \
            "$(csv_escape "$repo")" \
            "$(csv_escape "$(repo_health "$repo")")" \
            "$(csv_escape "$(repo_type "$repo")")" \
            "$(csv_escape "$(repo_branch "$repo")")" \
            "$(csv_escape "$(repo_default_remote_branch "$repo")")" \
            "$(csv_escape "$(repo_branch_counts "$repo")")" \
            "$(csv_escape "$(repo_state "$repo")")" \
            "$(csv_escape "$(repo_ahead_behind "$repo")")" \
            "$(csv_escape "$(repo_origin "$repo")")" \
            "$(csv_escape "$(repo_last_commit "$repo")")" \
            "$(csv_escape "$(repo_size "$repo")")"
    done < <(find_repos)
}

write_inventory() {
    if [ -z "$OUT" ]; then
        inventory_md
        return 0
    fi
    mkdir -p "$(dirname "$OUT")"
    case "$OUT" in
        *.csv) inventory_csv > "$OUT" ;;
        *) inventory_md > "$OUT" ;;
    esac
    cc_log "Inventory written: $OUT"
}

repo_fetch() {
    local repo="$1"
    if [ "$APPLY" -eq 1 ]; then
        git -C "$repo" fetch --all --prune
    else
        echo "DRY RUN: git -C '$repo' fetch --all --prune"
    fi
}

repo_pull() {
    local repo="$1"
    if [ "$(repo_state "$repo")" != "clean" ]; then
        echo "SKIP: working tree is dirty"
        return 0
    fi
    if ! git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
        echo "SKIP: no upstream configured"
        return 0
    fi
    if [ "$APPLY" -eq 1 ]; then
        git -C "$repo" pull --ff-only
    else
        echo "DRY RUN: git -C '$repo' pull --ff-only"
    fi
}

repo_backup() {
    local repo="$1" name stamp bundle
    name="$(basename "$repo")"
    stamp="$(date +%Y%m%d-%H%M%S)"
    bundle="$BUNDLE_DIR/${name}-${stamp}.bundle"
    if [ "$(repo_state "$repo")" != "clean" ]; then
        echo "SKIP: working tree is dirty"
        return 0
    fi
    if [ "$APPLY" -eq 1 ]; then
        mkdir -p "$BUNDLE_DIR"
        git -C "$repo" bundle create "$bundle" --all
        echo "WROTE: $bundle"
    else
        echo "DRY RUN: git -C '$repo' bundle create '$bundle' --all"
    fi
}

print_header

if [ ! -d "$ROOT" ]; then
    cc_error "Repository root not found: $ROOT"
    exit 1
fi

case "$ACTION" in
    list)
        find_repos
        ;;
    status)
        printf '%-34s %-10s %-10s %-16s %-8s %-22s %s\n' "Repository" "Health" "Type" "Branch" "State" "Sync" "Origin"
        printf '%-34s %-10s %-10s %-16s %-8s %-22s %s\n' "----------" "------" "----" "------" "-----" "----" "------"
        while read -r repo; do
            [ -n "$repo" ] || continue
            printf '%-34s %-10s %-10s %-16s %-8s %-22s %s\n' "$(basename "$repo")" "$(repo_health "$repo")" "$(repo_type "$repo")" "$(repo_branch "$repo")" "$(repo_state "$repo")" "$(repo_ahead_behind "$repo")" "$(repo_origin "$repo")"
        done < <(find_repos)
        summary_footer
        ;;
    health)
        printf '%-34s %-10s %-10s %-16s %-8s %-22s\n' "Repository" "Health" "Type" "Branch" "State" "Sync"
        printf '%-34s %-10s %-10s %-16s %-8s %-22s\n' "----------" "------" "----" "------" "-----" "----"
        while read -r repo; do
            [ -n "$repo" ] || continue
            printf '%-34s %-10s %-10s %-16s %-8s %-22s\n' "$(basename "$repo")" "$(repo_health "$repo")" "$(repo_type "$repo")" "$(repo_branch "$repo")" "$(repo_state "$repo")" "$(repo_ahead_behind "$repo")"
        done < <(find_repos)
        summary_footer
        ;;
    inventory)
        write_inventory
        ;;
    fetch)
        while read -r repo; do
            [ -n "$repo" ] || continue
            echo
            echo "[$(basename "$repo")] $repo"
            repo_fetch "$repo"
        done < <(find_repos)
        ;;
    pull)
        while read -r repo; do
            [ -n "$repo" ] || continue
            echo
            echo "[$(basename "$repo")] $repo"
            repo_pull "$repo"
        done < <(find_repos)
        ;;
    sync)
        while read -r repo; do
            [ -n "$repo" ] || continue
            echo
            echo "[$(basename "$repo")] $repo"
            repo_fetch "$repo"
            repo_pull "$repo"
        done < <(find_repos)
        ;;
    backup)
        printf '%-14s %s\n' "Bundle dir:" "$BUNDLE_DIR"
        while read -r repo; do
            [ -n "$repo" ] || continue
            echo
            echo "[$(basename "$repo")] $repo"
            repo_backup "$repo"
        done < <(find_repos)
        ;;
    verify|doctor)
        while read -r repo; do
            [ -n "$repo" ] || continue
            [ -x "$repo/tools/cc" ] || continue
            echo
            echo "[$(basename "$repo")] cc $ACTION"
            bash "$repo/tools/cc" "$ACTION" || true
        done < <(find_repos)
        ;;
esac
