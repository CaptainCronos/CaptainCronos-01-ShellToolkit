#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : defaults
# Version     : reads VERSION
# Category    : Engineering
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Promote active shell files into deployable defaults.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

case "${1:-}" in
    --help|-h)
        echo "Usage: cc defaults"
        echo
        echo "Promotes active shell files into defaults/v1."
        exit 0
        ;;
    --version)
        cc_version
        exit 0
        ;;
esac

install/promote-defaults.sh
