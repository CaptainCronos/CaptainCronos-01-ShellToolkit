#!/usr/bin/env bash
#
# ==============================================================================
# Captain Cronos Shell Toolkit
# ------------------------------------------------------------------------------
# Script      : audit
# Version     : 1.2.0-alpha1
# Category    : Engineering
# Requires    : bash awk grep find python3 chmod
# Repository  : CaptainCronos-01-ShellToolkit
# Purpose     : Run command consistency checks across toolkit commands.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$PROJECT_ROOT"
source "$PROJECT_ROOT/lib/cc-common.sh"

MODE="summary"
STRICT=0
APPLY=0

usage() {
    cat <<'EOF_HELP'
Usage:
  cc audit [summary|commands] [--strict]
  cc audit fix [--apply]

Runs consistency checks across tools/commands.

Default checks:
  - Bash syntax
  - Script header
  - Version header
  - Repository header
  - Purpose header
  - --help support
  - --version support

Strict checks add:
  - executable bit
  - Category header
  - Requires header

Fix mode:
  - Adds executable bit to tools/commands/*
  - Adds missing Category and Requires headers for known commands
  - Dry-run by default unless --apply is supplied

Notes:
  Most toolkit commands are dispatched by cc and do not require executable bits
  during normal operation, but repository command files should be executable for
  packaging and strict audit compliance.
EOF_HELP
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "1.2.0-alpha1"
            exit 0
            ;;
        --strict)
            STRICT=1
            shift
            ;;
        --apply)
            APPLY=1
            shift
            ;;
        summary|commands|fix)
            MODE="$1"
            shift
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

command_files() {
    find tools/commands -maxdepth 1 -type f -printf '%f\n' | sort
}

has_header() {
    local file="$1" header="$2"
    grep -qE "^# ${header}[[:space:]]*:" "$file"
}

check_command() {
    local cmd="$1" file="tools/commands/$cmd" issues=0
    local executable="skip" syntax="ok" script="ok" version="ok" category="skip" requires="skip" repository="ok" purpose="ok" help="ok" verflag="ok"

    if [ "$STRICT" -eq 1 ]; then
        executable="ok"
        category="ok"
        requires="ok"
        [ -x "$file" ] || { executable="warn"; issues=$((issues + 1)); }
        has_header "$file" Category || { category="warn"; issues=$((issues + 1)); }
        has_header "$file" Requires || { requires="warn"; issues=$((issues + 1)); }
    fi

    bash -n "$file" >/dev/null 2>&1 || { syntax="fail"; issues=$((issues + 1)); }
    has_header "$file" Script || { script="warn"; issues=$((issues + 1)); }
    has_header "$file" Version || { version="warn"; issues=$((issues + 1)); }
    has_header "$file" Repository || { repository="warn"; issues=$((issues + 1)); }
    has_header "$file" Purpose || { purpose="warn"; issues=$((issues + 1)); }
    bash "$file" --help >/dev/null 2>&1 || { help="warn"; issues=$((issues + 1)); }
    bash "$file" --version >/dev/null 2>&1 || { verflag="warn"; issues=$((issues + 1)); }

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$cmd" "$issues" "$executable" "$syntax" "$script" "$version" "$category" "$requires" "$repository" "$purpose" "$help" "$verflag"
}

rows() {
    command_files | while read -r cmd; do
        [ -n "$cmd" ] || continue
        check_command "$cmd"
    done
}

fix_known_metadata() {
    python3 - "$PROJECT_ROOT" "$APPLY" <<'PY'
import sys
from pathlib import Path

root = Path(sys.argv[1])
apply = sys.argv[2] == "1"
cmd_dir = root / "tools" / "commands"

meta = {
    "about": ("Core", "bash"),
    "asset": ("Core", "bash find cat mkdir awk grep sed"),
    "audit": ("Engineering", "bash awk grep find python3 chmod"),
    "baseline": ("Engineering", "bash"),
    "config": ("Core", "bash"),
    "defaults": ("Engineering", "bash"),
    "docs": ("Documentation", "bash git find awk"),
    "doctor": ("Diagnostics", "bash git awk df smartctl"),
    "drive-burnin": ("Storage", "bash smartctl date mkdir"),
    "drive-inventory": ("Storage", "bash lsblk smartctl awk sed grep"),
    "drive-qualify": ("Storage", "bash smartctl awk grep sed date mkdir"),
    "drive-report": ("Storage", "bash smartctl date mkdir awk sed grep"),
    "drives": ("Storage", "bash lsblk df awk"),
    "drive-smart": ("Storage", "bash smartctl awk grep sed"),
    "drive-test": ("Storage", "bash smartctl awk grep sed"),
    "gitflow": ("Repository", "bash git"),
    "helpme-refresh": ("Documentation", "bash python3"),
    "install": ("Core", "bash"),
    "kernel-cleanup": ("Storage", "bash apt dpkg uname awk"),
    "monthly-health": ("Maintenance", "bash date mkdir df uname uptime"),
    "monthly-health-timer": ("Maintenance", "bash systemctl"),
    "plugin": ("Core", "bash find"),
    "registry": ("Documentation", "bash awk find"),
    "release": ("Engineering", "bash git"),
    "repo": ("Repository", "bash git"),
    "repos": ("Repository", "bash git awk find du"),
    "roadmap": ("Documentation", "bash cat"),
    "smart": ("Storage", "bash smartctl lsblk awk sudo"),
    "status": ("Repository", "bash git"),
    "system-update": ("Maintenance", "bash apt flatpak snap"),
    "toolkit-update": ("Core", "bash git"),
    "update": ("Maintenance", "bash git"),
    "verify": ("Diagnostics", "bash find bash"),
    "version": ("Core", "bash"),
}

def has_header(text, name):
    return any(line.startswith(f"# {name}") and ":" in line for line in text.splitlines())

changed = []
for path in sorted(cmd_dir.iterdir()):
    if not path.is_file():
        continue
    cmd = path.name
    if cmd not in meta:
        continue
    category, requires = meta[cmd]
    text = path.read_text()
    lines = text.splitlines()
    if has_header(text, "Category") and has_header(text, "Requires"):
        continue
    out = []
    inserted = False
    for line in lines:
        out.append(line)
        if line.startswith("# Version") and not has_header(text, "Category"):
            out.append(f"# Category    : {category}")
        if line.startswith("# Category") and not has_header(text, "Requires"):
            out.append(f"# Requires    : {requires}")
        if line.startswith("# Version") and has_header(text, "Category") and not has_header(text, "Requires"):
            # If Category existed above or elsewhere, Requires will be added after Category only.
            pass
    new_text = "\n".join(out) + ("\n" if text.endswith("\n") else "")
    if new_text != text:
        changed.append(str(path.relative_to(root)))
        if apply:
            path.write_text(new_text)

for item in changed:
    print(item)
if not changed:
    print("No metadata changes needed.")
PY
}

case "$MODE" in
    summary)
        cc_banner
        echo
        echo "Command Consistency Audit"
        echo "-------------------------"
        printf '%-12s %s\n' "Strict:" "$STRICT"
        echo
        total=0
        clean=0
        warn=0
        fail=0
        while IFS=$'\t' read -r cmd issues executable syntax script version category requires repository purpose help verflag; do
            total=$((total + 1))
            if [ "$syntax" = "fail" ]; then
                fail=$((fail + 1))
            elif [ "$issues" -eq 0 ]; then
                clean=$((clean + 1))
            else
                warn=$((warn + 1))
            fi
        done < <(rows)
        printf '%-12s %s\n' "Commands:" "$total"
        printf '%-12s %s\n' "Clean:" "$clean"
        printf '%-12s %s\n' "Warnings:" "$warn"
        printf '%-12s %s\n' "Failures:" "$fail"
        echo
        if [ "$warn" -gt 0 ] || [ "$fail" -gt 0 ]; then
            echo "Run detail: cc audit commands"
        fi
        [ "$fail" -eq 0 ] || exit 1
        ;;
    commands)
        cc_banner
        echo
        printf '%-22s %-6s %-5s %-6s %-6s %-7s %-8s %-8s %-10s %-8s %-6s %-8s\n' \
            "Command" "Issues" "Exec" "Syntax" "Script" "Version" "Category" "Requires" "Repository" "Purpose" "Help" "VerFlag"
        printf '%-22s %-6s %-5s %-6s %-6s %-7s %-8s %-8s %-10s %-8s %-6s %-8s\n' \
            "-------" "------" "----" "------" "------" "-------" "--------" "--------" "----------" "-------" "----" "-------"
        rows | while IFS=$'\t' read -r cmd issues executable syntax script version category requires repository purpose help verflag; do
            printf '%-22s %-6s %-5s %-6s %-6s %-7s %-8s %-8s %-10s %-8s %-6s %-8s\n' \
                "$cmd" "$issues" "$executable" "$syntax" "$script" "$version" "$category" "$requires" "$repository" "$purpose" "$help" "$verflag"
        done
        ;;
    fix)
        cc_banner
        echo
        printf '%-12s %s\n' "Apply:" "$APPLY"
        echo
        if [ "$APPLY" -eq 0 ]; then
            cc_log "DRY RUN: would chmod +x tools/commands/* and add missing metadata headers."
            echo
            fix_known_metadata
            echo
            cc_log "Re-run with: cc audit fix --apply"
            exit 0
        fi
        chmod +x tools/commands/*
        cc_log "Applied executable bit to tools/commands/*"
        fix_known_metadata
        cc_log "Audit fix complete. Review with: git diff -- tools/commands"
        ;;
esac
